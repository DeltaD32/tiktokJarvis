# Copy to .env and fill in. This file is a template; .env is git-ignored.

# The brain provider (OpenAI-compatible endpoint).
# For OpenCode GO / Zen, set DELA_BASE_URL to the endpoint and DELA_API_KEY to your key.
# For Ollama (local), set DELA_BASE_URL=http://localhost:11434/v1 and DELA_API_KEY=ollama,
# and DELA_MODEL to a model you have pulled (e.g. llama3.1).
DELA_BASE_URL=https://api.openai.com/v1
DELA_API_KEY=replace-me
DELA_MODEL=gpt-4o-mini

# Profile-specific API connections (optional — overrides the generic vars above).
# Set DELA_PROFILE above to choose which profile is active at startup.
# If profile-specific vars are not set, Dela falls back to DELA_BASE_URL/API_KEY/MODEL.
# PERSONAL: use GLM-5.2 at home
DELA_PERSONAL_BASE_URL=https://api.openai.com/v1
DELA_PERSONAL_API_KEY=replace-me
DELA_PERSONAL_MODEL=glm-5.2
# WORK: forced to use a different provider/model at work
DELA_WORK_BASE_URL=https://api.anthropic.com/v1
DELA_WORK_API_KEY=replace-me
DELA_WORK_MODEL=claude-sonnet-4-6

# Dela's identity (used in the system prompt).
DELA_NAME=Dela

# Security profile: "personal" (full access, standard security) or "work" (enterprise-grade, restricted tools, WIZ integration).
# Default is "personal" if not set. Switch via Settings panel or set here.
DELA_PROFILE=personal

# Voice (Tier 3) — fully local stack. No API keys needed.
DELA_MODELS_DIR=D:\projects\tiktokJarvis\models
DELA_WHISPER_MODEL=small.en
DELA_WHISPER_DEVICE=cuda
DELA_WHISPER_COMPUTE=float16
DELA_PIPER_VOICE=en_US-amy-medium
DELA_VAD_AGGRESSIVENESS=3

# Thinking level (off/minimal/low/medium/high/xhigh — model-dependent, empty = don't send)
DELA_THINKING_LEVEL=

# Compaction (auto-summarize when conversation gets long)
DELA_COMPACTION_THRESHOLD_CHARS=100000
DELA_COMPACTION_KEEP_RECENT_CHARS=20000

# Tracing (optional). Set to "langsmith" or "langfuse" to enable. Leave empty to disable.
DELA_TRACING_PROVIDER=
DELA_TRACING_PROJECT=dela
DELA_TRACING_API_KEY=
DELA_TRACING_ENDPOINT=

# IM Channels (see channels_config.json for settings)
# Telegram
DELA_TELEGRAM_BOT_TOKEN=
# Teams Webhook
DELA_TEAMS_WEBHOOK_URL=
DELA_TEAMS_VERIFY_TOKEN=
# Graph API
DELA_GRAPH_CLIENT_ID=
DELA_GRAPH_CLIENT_SECRET=
DELA_GRAPH_TENANT_ID=
DELA_GRAPH_TARGET_ID=
