# Copy to .env and fill in. This file is a template; .env is git-ignored.

# ═══════════════════════════════════════════════════════════════════════════
# LLM PROVIDER — choose one of three modes:
# ═══════════════════════════════════════════════════════════════════════════

# ── Mode 1: CLOUD API (OpenAI, OpenCode GO, etc.) ──────────────────────────
DELA_BASE_URL=https://api.openai.com/v1
DELA_API_KEY=replace-me
DELA_MODEL=gpt-4o-mini

# ── Mode 2: LOCAL (Ollama) — fully offline ─────────────────────────────────
# Install Ollama from https://ollama.com, then:
#   ollama pull llama3.1          (or qwen2.5, phi3, mistral, etc.)
#   ollama serve                  (starts the server on port 11434)
# Then set these and comment out the cloud vars above:
# DELA_BASE_URL=http://localhost:11434/v1
# DELA_API_KEY=ollama
# DELA_MODEL=llama3.1

# ── Mode 3: PROFILE-SPECIFIC (different models per context) ────────────────
# Set DELA_PROFILE below to choose which profile is active at startup.
# If profile-specific vars are not set, Dela falls back to DELA_* above.
# PERSONAL: e.g. GLM-5.2 at home
DELA_PERSONAL_BASE_URL=https://api.openai.com/v1
DELA_PERSONAL_API_KEY=replace-me
DELA_PERSONAL_MODEL=glm-5.2
# WORK: e.g. Claude at the office
DELA_WORK_BASE_URL=https://api.anthropic.com/v1
DELA_WORK_API_KEY=replace-me
DELA_WORK_MODEL=claude-sonnet-4-6
# OFFLINE: local Ollama — no internet required
# When DELA_PROFILE=offline, these vars are used (falling back to DELA_* if not set)
DELA_OFFLINE_BASE_URL=http://localhost:11434/v1
DELA_OFFLINE_API_KEY=ollama
DELA_OFFLINE_MODEL=llama3.1

# ═══════════════════════════════════════════════════════════════════════════
# IDENTITY
# ═══════════════════════════════════════════════════════════════════════════
DELA_NAME=Dela

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY PROFILE
#   personal — full access, standard security (default)
#   work     — enterprise-grade, restricted tools, WIZ integration
#   offline  — fully local, blocks web-dependent tools, pairs with Ollama
# ═══════════════════════════════════════════════════════════════════════════
DELA_PROFILE=personal

# ═══════════════════════════════════════════════════════════════════════════
# VOICE — fully local stack. No API keys needed. Works offline.
# ═══════════════════════════════════════════════════════════════════════════
DELA_MODELS_DIR=D:\projects\tiktokJarvis\models
DELA_WHISPER_MODEL=small.en
DELA_WHISPER_DEVICE=cuda
DELA_WHISPER_COMPUTE=float16
DELA_PIPER_VOICE=en_US-amy-medium
DELA_VAD_AGGRESSIVENESS=3

# ═══════════════════════════════════════════════════════════════════════════
# THINKING & COMPACTION
# ═══════════════════════════════════════════════════════════════════════════
DELA_THINKING_LEVEL=
DELA_COMPACTION_THRESHOLD_CHARS=100000
DELA_COMPACTION_KEEP_RECENT_CHARS=20000

# ═══════════════════════════════════════════════════════════════════════════
# TRACING (optional — leave empty to disable)
# ═══════════════════════════════════════════════════════════════════════════
DELA_TRACING_PROVIDER=
DELA_TRACING_PROJECT=dela
DELA_TRACING_API_KEY=
DELA_TRACING_ENDPOINT=

# ═══════════════════════════════════════════════════════════════════════════
# MULTI-USER AUTH (set DELA_MULTI_USER=1 to enable)
# ═══════════════════════════════════════════════════════════════════════════
# DELA_MULTI_USER=1                         # Set to 1 to enable multi-user mode
# DELA_JWT_SECRET=                          # Auto-generated on first run
# DELA_ADMIN_EMAIL=admin@dela.local         # Default admin email (first run only)
# DELA_ADMIN_PASSWORD=changeme              # Default admin password (first run only)
# DELA_ACCESS_TOKEN_EXPIRY=24               # Hours
# DELA_REFRESH_TOKEN_EXPIRY=30              # Days
# DELA_MAX_LOGIN_ATTEMPTS=5                 # Rate limit threshold
# DELA_LOGIN_LOCKOUT_MINUTES=15             # Lockout duration

# ═══════════════════════════════════════════════════════════════════════════
# IM CHANNELS (see channels_config.json for settings)
# ═══════════════════════════════════════════════════════════════════════════
DELA_TELEGRAM_BOT_TOKEN=
DELA_TEAMS_WEBHOOK_URL=
DELA_TEAMS_VERIFY_TOKEN=
DELA_GRAPH_CLIENT_ID=
DELA_GRAPH_CLIENT_SECRET=
DELA_GRAPH_TENANT_ID=
DELA_GRAPH_TARGET_ID=
