{
  "heartbeat_interval_seconds": 30,
  "quiet_hours": {
    "enabled": true,
    "start": "22:00",
    "end": "08:00"
  },
  "checks": {
    "systems_health": {
      "enabled": true,
      "interval_seconds": 120,
      "targets": [
        "https://www.google.com",
        "8.8.8.8:53"
      ],
      "surface_on": "down"
    },
    "tasks_due": {
      "enabled": true,
      "interval_seconds": 300,
      "look_ahead_hours": 24,
      "surface_on": "due_soon"
    },
    "blackboard_cleanup": {
      "enabled": true,
      "interval_seconds": 600,
      "surface_on": "cleaned"
    },
    "scheduled_workflows": {
      "enabled": true,
      "interval_seconds": 300,
      "surface_on": "ran"
    },
    "security_scan": {
      "enabled": true,
      "interval_seconds": 3600,
      "surface_on": "critical"
    },
    "vuln_kb_refresh": {
      "enabled": true,
      "interval_seconds": 86400,
      "surface_on": "updated"
    }
  },
  "interval": 60
}